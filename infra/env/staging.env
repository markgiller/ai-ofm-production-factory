# ── Runtime ──────────────────────────────────────────────────────────────────
ENV=staging
COMFYUI_PORT=8188
VRAM_MODE=highvram
NETWORK_VOLUME_PATH=/workspace
COMFYUI_VERSION=v0.16.4

# ── Cache dirs on volume (survives pod restarts) ──────────────────────────────
# Without these, HF downloads and pip cache go into the ephemeral container.
HF_HOME=/workspace/.cache/huggingface
PIP_CACHE_DIR=/workspace/.pip_cache

# ── S3 / Object Storage ──────────────────────────────────────────────────────
S3_ENDPOINT_URL=
S3_BUCKET_NAME=ofm-staging
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=auto

# ── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=ofm_staging
POSTGRES_USER=
POSTGRES_PASSWORD=
