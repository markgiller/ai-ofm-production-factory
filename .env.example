# ==============================================================================
# AI OFM Production Factory — Environment Variables Template
# ==============================================================================
# Usage:
#   cp .env.example infra/env/staging.env    → fill in staging values
#   cp .env.example infra/env/production.env → fill in production values
#
# RULE: infra/env/staging.env and infra/env/production.env are gitignored.
# This file (.env.example) is the only env file committed to the repo.
# Never put real credentials in this file.
# ==============================================================================

# ── Runtime ───────────────────────────────────────────────────────────────────

# Environment label. Used in logs and metadata.
# Valid values: staging | production
ENV=staging

# Port ComfyUI listens on inside the container.
# Host-side mapping in docker-compose uses this value.
# Default: 8188
COMFYUI_PORT=8188

# ComfyUI VRAM allocation strategy.
# Valid values:
#   highvram   — keep models in VRAM between runs (RTX 4090 24GB → use this)
#   normalvram — balanced offloading for 12-16GB cards
#   lowvram    — aggressive offloading for 8-10GB cards
#   cpu        — CPU-only, no GPU (for local debugging only, very slow)
VRAM_MODE=highvram

# Absolute path where the Runpod network volume is mounted.
# On Runpod: always /workspace (set automatically by the platform)
# Local dev: any local path, e.g. ./local_workspace
NETWORK_VOLUME_PATH=/workspace

# ComfyUI release tag used when building the Docker image.
# Used by docker-compose build args and the Dockerfile ARG.
# Check latest: https://github.com/Comfy-Org/ComfyUI/releases
COMFYUI_VERSION=v0.16.4

# Path for HuggingFace model cache on the network volume.
# Without this, HF downloads (~/.cache/huggingface) go into the ephemeral
# container and are lost on every pod restart.
# Must be on NETWORK_VOLUME_PATH so it survives between pod sessions.
HF_HOME=/workspace/.cache/huggingface

# Path for pip package cache on the network volume.
# Speeds up custom node requirements installs on subsequent pod starts.
# Without this, pip re-downloads packages from PyPI every time.
PIP_CACHE_DIR=/workspace/.pip_cache

# ── S3 / Object Storage ───────────────────────────────────────────────────────

# Full URL of the S3-compatible endpoint.
# Provider: Backblaze B2 (recommended — allows legal adult content, S3-compatible).
# Backblaze B2:   https://s3.<region>.backblazeb2.com
#   Example:      https://s3.us-west-004.backblazeb2.com
# Cloudflare R2 is NOT suitable — their ToS prohibits adult content.
S3_ENDPOINT_URL=

# S3 bucket name — SFW lane.
# Bucket names use hyphens per naming_convention.md §16.
# Staging:    ofm-staging
# Production: ofm-prod
S3_BUCKET_NAME=ofm-staging

# S3 bucket name — Adult lane.
# SFW and adult assets must NEVER share a bucket (naming_convention §17).
# Both buckets live on the same provider (Backblaze B2) — same credentials, same endpoint.
# Staging:    ofm-staging-adult
# Production: ofm-prod-adult
S3_BUCKET_NAME_ADULT=ofm-staging-adult

# S3 access key (public half of credential pair)
S3_ACCESS_KEY=

# S3 secret key — NEVER put a real value here
S3_SECRET_KEY=

# S3 region.
# Backblaze B2: the region name from your bucket (e.g. us-west-004, eu-central-003)
# AWS S3:       us-east-1 (or your actual region)
S3_REGION=

# ── Postgres / Metadata ───────────────────────────────────────────────────────

# Hostname or IP of the Postgres server.
# docker-compose same network: use service name, e.g. postgres
# Managed service (Supabase, Neon, Railway): use the provided hostname
POSTGRES_HOST=

# Postgres port. Change only if your provider uses a non-standard port.
POSTGRES_PORT=5432

# Database name.
# Staging:    ofm_staging
# Production: ofm_prod
POSTGRES_DB=ofm_staging

# Postgres username — NEVER put a real value here
POSTGRES_USER=

# Postgres password — NEVER put a real value here
POSTGRES_PASSWORD=

# ── ComfyUI ───────────────────────────────────────────────────────────────────

# URL of the running ComfyUI instance.
# Used by orchestrator services and verify scripts.
# Runpod: Connect tab → Expose HTTP Ports → copy URL for port 8188
#   format: https://<pod_id>-8188.proxy.runpod.net
# Local dev: http://localhost:8188
COMFYUI_URL=
